{
	"name": "openhammer",
	"version": "0.1.0",
	"description": "Standalone MCP server (no LLM) exposing local shell/filesystem tools to a remote agent over Streamable HTTP.",
	"type": "module",
	"main": "dist/main.js",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/main.js",
		"dev": "tsx watch src/main.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src",
		"format": "biome format --write src"
	},
	"dependencies": {
		"@fastify/cors": "^8.5.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"fastify": "^4.29.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^20.19.43",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
