{
	"name": "openhammer",
	"version": "0.1.0",
	"description": "Standalone MCP server (no LLM) exposing local shell/filesystem tools to a remote agent over Streamable HTTP.",
	"type": "module",
	"main": "dist/main.js",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/main.js",
		"dev": "NODE_ENV=development tsx watch src/main.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome check src test",
		"format": "biome format --write src test",
		"test:compose": "docker compose up --build --exit-code-from test-runner --abort-on-container-exit",
		"test:compose:real": "docker compose --profile real up --build --exit-code-from real-test-runner --abort-on-container-exit real-test-runner",
		"test:in-container": "docker compose run --rm dev npm test",
		"test:tunnel": "bash scripts/test-tunnel.sh"
	},
	"dependencies": {
		"@fastify/cors": "^8.5.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"fastify": "^4.29.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^20.19.43",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
