# OpenHammer — example environment.
# Copy to `.env` and load with Node `--env-file=.env`, or export in your shell.
# Every variable is optional; the value shown is the default.

PORT=3000                       # HTTP port
HOST=127.0.0.1                  # bind address (use 0.0.0.0 to expose on LAN)
MCP_ROOT_DIR=                   # tool filesystem root; empty = launch cwd
MCP_AUTH_TOKEN=                 # override the minted bearer token (optional)
MCP_PUBLIC_URL=                 # public base URL advertised in OAuth discovery (optional; auto from a tunnel, else http://$HOST:$PORT)
OAUTH_JWT_SECRET=               # HS256 secret for the OAuth client-credentials AS (optional; minted into credentials.json on first use)
MCP_MAX_RESPONSE_BYTES=512000   # universal tools/call size backstop
LOG_LEVEL=info                  # pino level
